pipeline {
    agent any

    environment {
        DOCKER_USERNAME = "yourdockerhub"
        IMAGE_BACKEND = "backend"
        IMAGE_FRONTEND = "frontend"
    }

    stages {

        stage('Clone Repository') {
            steps {
                git 'https://github.com/itsakrana/Microservices_project.git'
            }
        }

        stage('Build Backend Image') {
            steps {
                sh 'docker build -t $DOCKER_USERNAME/$IMAGE_BACKEND ./backend'
            }
        }

        stage('Build Frontend Image') {
            steps {
                sh 'docker build -t $DOCKER_USERNAME/$IMAGE_FRONTEND ./frontend'
            }
        }

        stage('Push Images') {
            steps {
                sh 'docker push $DOCKER_USERNAME/$IMAGE_BACKEND'
                sh 'docker push $DOCKER_USERNAME/$IMAGE_FRONTEND'
            }
        }

    }
}
