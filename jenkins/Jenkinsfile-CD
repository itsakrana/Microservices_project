pipeline {
    agent any

    stages {

        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                kubectl create namespace production || true
                kubectl apply -f k8s/ -n production --validate=false
                '''
            }
        }

        stage('Check Deployment') {
            steps {
                sh 'kubectl get pods -n production'
                sh 'kubectl get svc -n production'
            }
        }

    }
}
